# --- Mapbox ---------------------------------------------------------------
# Required by the React frontend. Get a free token at https://account.mapbox.com/
REACT_APP_MAPBOX_TOKEN=

# --- Backend --------------------------------------------------------------
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# --- Sentinel satellite backend (pick ONE if you want real Sentinel data) -
# Sentinel Hub
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# OR Google Earth Engine (path to service-account JSON key)
GEE_SERVICE_ACCOUNT_KEY=

# --- Optional NI / OpenDataNI -------------------------------------------
# Some OpenDataNI datasets behind admin.opendatani.gov.uk need a key.
OPENDATANI_API_KEY=
